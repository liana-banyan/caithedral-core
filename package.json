{
  "name": "caithedral-core",
  "version": "0.2.1",
  "description": "Caithedral™ Core — Cooperative AI Memory Architecture · Reference Implementation · Designed to Be Copied",
  "homepage": "https://mnemosynec.ai",
  "private": false,
  "license": "SSPL-1.0",
  "main": "dist/main/main/index.js",
  "exports": {
    ".": "./dist/main/main/index.js",
    "./tools/soccerball": "./dist/main/tools/soccerball_tools.js",
    "./tools/pearl": "./dist/main/tools/pearl_tools.js",
    "./tools/eblit": "./dist/main/tools/eblit_tools.js",
    "./tools/substrace": "./dist/main/tools/substrace_tools.js",
    "./tools/quilt": "./dist/main/tools/quilt_tools.js",
    "./tools/substrate_address": "./dist/main/tools/substrate_address.js",
    "./tools/dag_soccerball": "./dist/main/tools/dag_soccerball_tools.js",
    "./tools/soccerball.ts": "./src/tools/soccerball_tools.ts",
    "./tools/dag_soccerball.ts": "./src/tools/dag_soccerball_tools.ts",
    "./tools/pearl.ts": "./src/tools/pearl_tools.ts",
    "./tools/eblit.ts": "./src/tools/eblit_tools.ts",
    "./tools/substrace.ts": "./src/tools/substrace_tools.ts",
    "./tools/quilt.ts": "./src/tools/quilt_tools.ts",
    "./tools/substrate_address.ts": "./src/tools/substrate_address.ts",
    "./src/tools/soccerball_tools.ts": "./src/tools/soccerball_tools.ts",
    "./src/tools/pearl_tools.ts": "./src/tools/pearl_tools.ts",
    "./src/tools/eblit_tools.ts": "./src/tools/eblit_tools.ts",
    "./src/tools/substrace_tools.ts": "./src/tools/substrace_tools.ts",
    "./src/tools/quilt_tools.ts": "./src/tools/quilt_tools.ts",
    "./src/tools/substrate_address.ts": "./src/tools/substrate_address.ts",
    "./src/tools/dag_soccerball_tools.ts": "./src/tools/dag_soccerball_tools.ts"
  },
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"wait-on http://127.0.0.1:5173 && npm run dev:main\"",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "test:smoke": "tsc -p tsconfig.json --noEmit && node --loader ts-node/esm tests/smoke.test.ts"
  },
  "keywords": [
    "caithedral-core",
    "cai-core",
    "cooperative-ai",
    "memory-architecture",
    "caithedral",
    "eblet",
    "banyan-metric",
    "speckle",
    "soccerball",
    "pearl"
  ],
  "author": "Liana Banyan Corporation",
  "repository": {
    "type": "git",
    "url": "https://github.com/liana-banyan/cai-core.git"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@peculiar/asn1-schema": "^2.7.0",
    "@peculiar/asn1-tsp": "^2.7.0",
    "@peculiar/asn1-x509": "^2.7.0",
    "allotment": "^1.20.5",
    "electron-updater": "^6.1.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0",
    "ws": "^8.20.1"
  },
  "build": {
    "appId": "com.lianabanyan.caithedralcore",
    "productName": "Caithedral Core",
    "icon": "assets/app-icon",
    "copyright": "Copyright © 2026 Liana Banyan Corporation",
    "asar": true,
    "asarUnpack": [
      "resources/ollama/**"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "assets/tray-icon.png",
      "assets/app-icon.ico",
      "assets/app-icon.png",
      "assets/app-icon-*.png",
      "src/renderer/public/**/*",
      "static/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**",
      "!node_modules/**/{test,__tests__,tests,powered-test,example,examples}/**"
    ],
    "extraResources": [
      {
        "from": "resources/ollama",
        "to": "ollama",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "generic",
      "url": "https://mnemosynec.ai/download/",
      "channel": "latest"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signingHashAlgorithms": [
        "sha256"
      ],
      "signDlls": false,
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "artifactName": "Caithedral-Core-Keystone-I-Setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Caithedral Core",
      "include": "assets/installer.nsh",
      "license": "assets/LICENSE.rtf",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "Caithedral-Core-Keystone-I-Portable.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "notarize": false,
      "identity": null
    },
    "dmg": {
      "title": "Caithedral Core Keystone I",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "internetEnabled": false
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office",
      "maintainer": "Liana Banyan Corporation <licensing@mnemosynec.ai>",
      "synopsis": "Caithedral™ Core — Cooperative AI Memory Architecture · Reference Implementation",
      "description": "Caithedral™ Core runs the complete cooperative AI memory substrate: Caithedral™ retrieval, Pheromone substrate, Cross-Vendor symmetric MCP, Banyan Metric™ scoring. No cloud account. No central server. SSPL-1.0 + Cooperative Patent Pledge #2260."
    },
    "deb": {
      "packageCategory": "utils",
      "priority": "optional",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils"
      ]
    },
    "rpm": {
      "packageCategory": "Applications/Internet"
    }
  }
}
